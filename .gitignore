# -------------------------------------------------------------------------
# Flutter & Dart gitignore
# -------------------------------------------------------------------------

# https://dart.dev/guides/libraries/private-files

# Miscellaneous / OS-specific files
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
*.orig
*.rej
*~

# IDE and Editor files
*.iml
*.ipr
*.iws
.idea/
.vscode/
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.factorypath
.externalToolBuilders/

# Flutter / Dart / Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins
.pub-cache/
.pub/
.packages
/build/
**/build/
/coverage/

# Android-specific build, credentials, and local files
.gradle/
build/
Captures/
/android/local.properties
/android/key.properties
/android/app/local.properties
/android/app/key.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
*.keystore
*.jks
*.apk
*.aab
/android/app/src/main/res/raw/google_services.json
/android/app/src/main/res/values/google-services.xml

# iOS-specific build and local files
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Ephemeral/
.xcworkspace/
xcuserdata/
Pods/
Podfile.lock

# macOS / Linux / Windows desktop build outputs
/linux/flutter/ephemeral/
/macos/Flutter/ephemeral/
/windows/flutter/ephemeral/
/windows/flutter/generated_plugin_registrant.cc
/windows/flutter/generated_plugin_registrant.h
/windows/flutter/generated_plugins.cmake

# Generated Flutter plugin registrants
/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.kt

# Symbolication and Obfuscation related
app.*.symbols
app.*.map.json

# Generated code
# *.g.dart is often committed in Flutter projects for Isar/Riverpod
*.freezed.dart

