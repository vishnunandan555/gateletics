# -------------------------------------------------------------------------
# Flutter & Dart gitignore
# -------------------------------------------------------------------------

# https://dart.dev/guides/libraries/private-files

# Miscellaneous / OS-specific files
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
*~

# IDE and Editor files
*.iml
*.ipr
*.iws
.idea/
.vscode/

# Flutter / Dart / Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/
/coverage/

# Android-specific build, credentials, and local files
/android/local.properties
/android/key.properties
/android/app/local.properties
/android/app/key.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
*.keystore
*.jks
*.apk
*.aab

# iOS-specific build and local files
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Ephemeral/
.xcworkspace/
xcuserdata/
Pods/
Podfile.lock

# macOS / Linux / Windows desktop build outputs
/linux/flutter/ephemeral/
/macos/Flutter/ephemeral/
/windows/flutter/ephemeral/

# Symbolication and Obfuscation related
app.*.symbols
app.*.map.json
